{
  "name": "01-Heartbeat Gate Check",
  "nodes": [
    {
      "parameters": {
        "triggerTz": "Asia/Riyadh"
      },
      "id": "cron-trigger",
      "name": "Cron (every 6h)",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [50, 250]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://127.0.0.1:8099/dispatch",
        "authentication": "headerAuth",
        "headerAuth": "{{ $credentials.sofiGatewayToken }}",
        "sendHeaders": true,
        "contentType": "application/json",
        "body": {
          "role": "sofi-ceo",
          "project": "PRJ-SAKK",
          "command": "sofi gate-check PRJ-SAKK",
          "priority": "low",
          "source": "n8n-heartbeat",
          "trigger": "cron-6h"
        }
      },
      "id": "gateway-dispatch",
      "name": "SOFI Gateway - Gate Check",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [250, 250]
    },
    {
      "parameters": {
        "javascriptCode": "return $json.success ? {\n  status: 'ok',\n  gate: $json.response?.match(/Gate (\\d+)/)?.[1] || 'unknown',\n  blockers: $json.response?.includes('blocker') ? true : false\n} : {\n  status: 'error',\n  error: $json.error\n};"
      },
      "id": "parse-result",
      "name": "Parse Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [450, 250]
    },
    {
      "parameters": {
        "conditions": {
          "condition": "any",
          "combinator": "or",
          "rules": [
            {
              "leftValue": "{{ $json.status }}",
              "condition": "equals",
              "rightValue": "error"
            }
          ]
        }
      },
      "id": "check-error",
      "name": "IF Error?",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [650, 250]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "{{ $env.SLACK_WEBHOOK_URL }}",
        "contentType": "application/json",
        "body": {
          "text": "ð´ Heartbeat FAILED",
          "attachments": [
            {
              "color": "danger",
              "title": "SOFI Gate Check Error",
              "text": "{{ $json.error }}"
            }
          ]
        }
      },
      "id": "slack-error",
      "name": "Slack: Error Alert",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [850, 100]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "{{ $env.SLACK_WEBHOOK_URL }}",
        "contentType": "application/json",
        "body": {
          "text": "â Heartbeat OK",
          "attachments": [
            {
              "color": "good",
              "title": "SOFI Gate Status",
              "fields": [
                { "title": "Gate", "value": "{{ $json.gate }}", "short": true },
                { "title": "Blockers", "value": "{{ $json.blockers ? 'yes' : 'no' }}", "short": true }
              ]
            }
          ]
        }
      },
      "id": "slack-ok",
      "name": "Slack: Success",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [850, 400]
    }
  ],
  "connections": {
    "cron-trigger": {
      "main": [
        [{ "node": "gateway-dispatch", "type": "main", "index": 0 }]
      ]
    },
    "gateway-dispatch": {
      "main": [
        [{ "node": "parse-result", "type": "main", "index": 0 }]
      ]
    },
    "parse-result": {
      "main": [
        [{ "node": "check-error", "type": "main", "index": 0 }]
      ]
    },
    "check-error": {
      "main": [
        [{ "node": "slack-error", "type": "main", "index": 0 }],
        [{ "node": "slack-ok", "type": "main", "index": 0 }]
      ]
    }
  },
  "active": true,
  "settings": {
    "executionOrder": "v1",
    "timezone": "Asia/Riyadh"
  },
  "staticData": null,
  "versionId": "1"
}
