      "name": "Status Msg Build",
      "parameters": {
        "jsCode": "const GATES = [\n  {n:0,name:'Inception',role:'chief-product-strategist',approve:false},\n  {n:1,name:'Discovery',role:'ux-researcher',approve:false},\n  {n:2,name:'Design',role:'ui-ux-designer',approve:false},\n  {n:3,name:'Architecture',role:'principal-system-architect',approve:true},\n  {n:4,name:'Build',role:'tier-2-advisor',approve:true},\n  {n:5,name:'Quality',role:'qa-sre-lead',approve:false},\n  {n:6,name:'Staging',role:'devops-cloud-lead',approve:true},\n  {n:7,name:'Prod',role:'devops-cloud-lead',approve:true},\n  {n:8,name:'Observe',role:'observability-sre',approve:false},\n];\nconst r=$input.first().json; if(!r||r.id==null) return [{json:{chatId:$('Auth & Parse').first().json.chatId,msg:'لا توجد ميزة بهذا الرقم.'}}];\nconst g=GATES[Number(r.gate)]||GATES[0];\nconst msg = `🧭 الميزة #${r.id}: \"${r.title}\"\\nالبوابة: ${g.n} (${g.name})\\nالحالة: ${r.status}\\n\\n${(r.last_output||'').slice(0,600)}`;\nreturn [{ json: { chatId:r.chat_id, msg } }];"
