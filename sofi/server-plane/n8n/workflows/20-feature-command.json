    {
      "id": "build",
      "name": "Build Gate Payload",
      "parameters": {
        "jsCode": "const GATES = [\n  {n:0,name:'Inception',role:'chief-product-strategist',approve:false},\n  {n:1,name:'Discovery',role:'ux-researcher',approve:false},\n  {n:2,name:'Design',role:'ui-ux-designer',approve:false},\n  {n:3,name:'Architecture',role:'principal-system-architect',approve:true},\n  {n:4,name:'Build',role:'tier-2-advisor',approve:true},\n  {n:5,name:'Quality',role:'qa-sre-lead',approve:false},\n  {n:6,name:'Staging',role:'devops-cloud-lead',approve:true},\n  {n:7,name:'Prod',role:'devops-cloud-lead',approve:true},\n  {n:8,name:'Observe',role:'observability-sre',approve:false},\n];\nconst d=$input.first().json; const g=GATES[d.gate]||GATES[0];\nconst base='http://127.0.0.1:5678';\nconst command = `SOFI feature lifecycle — Gate ${g.n} (${g.name}) for feature #${d.featureId}: \"${d.title}\".\\n\\n`\n  + `Previous gate output:\\n${d.last_output || '(none — first gate)'}\\n\\n`\n  + `Do Gate ${g.n} (${g.name}) work per SOFI doctrine for THIS feature only. Produce the gate deliverable, `\n  + `check the gate bar, and finish with a short WhatsApp-readable Arabic summary (<=1000 chars) of what you `\n  + `produced and whether the gate bar is met — plain lines, no markdown tables or file trees.`;\nreturn [{ json: { role:g.role, project:'PRJ-SAKK', model:'sonnet', mode:'async', source:'whatsapp-feature',\n  command, callback_url:`${base}/webhook/sofi-feature-cb`, meta:{ featureId:d.featureId, gate:g.n, chatId:d.chatId },\n  _gateName:g.name, _featureId:d.featureId, _gate:g.n, _chatId:d.chatId } }];"
      },
      "position": [
        1280,
        304
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
