{
  "$schema": "sofi-schema.json",
  "version": "1.0",
  "name": "Lorka Monorepo",
  "description": "SOFI multi-project enterprise workspace",
  "agents": {
    "path": ".claude/agents"
  },
  "projects": {},
  "workspace": {
    "root": ".",
    "gitRoot": ".git",
    "ignore": [
      "node_modules",
      "vendor",
      "dist",
      ".env*",
      ".sofi-run",
      "worktrees"
    ]
  },
  "integrations": {
    "sofi": {
      "enabled": true,
      "version": "6.0",
      "rostersPath": "company/ORG.md",
      "registryPath": "company/nexus/registry.yaml",
      "constitutionPath": "company/CONSTITUTION.md",
      "protocolsPath": "company/constitution"
    }
  }
}
