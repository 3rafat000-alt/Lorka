#!/usr/bin/env bash
# sofi-hosts — minimal, bounded /etc/hosts editor for SOFI local domains.
#
# SECURITY MODEL: this script is the ONLY thing whitelisted for passwordless
# sudo (see `sofi domain init`). `sofi domain init` installs a ROOT-OWNED copy
# at /usr/local/sbin/sofi-hosts (not the repo copy, which the user can edit) and
# points the sudoers rule at that copy. The script can only:
#   - add/remove a single 127.0.0.1 line tagged with the SOFI marker, and
#   - for a hostname that passes a strict `*.local` regex.
# It can never write arbitrary content to /etc/hosts. Keep it that way.
set -euo pipefail

MARKER="# sofi-domain"
HOSTS="${SOFI_HOSTS_FILE:-/etc/hosts}"   # override only for tests

usage() { echo "usage: sofi-hosts <add|del> <slug.local>" >&2; exit 2; }

op="${1:-}"; name="${2:-}"
[ -n "$op" ] && [ -n "$name" ] || usage

# Strict allow-list: dns labels, must end in .local. Rejects spaces, slashes,
# comment chars, IPs — anything that could smuggle a second hosts directive.
if ! printf '%s' "$name" | grep -Eq '^[a-z0-9]([a-z0-9-]*[a-z0-9])?(\.[a-z0-9]([a-z0-9-]*[a-z0-9])?)*\.local$'; then
  echo "✗ refusing invalid host name: '$name' (must match <slug>.local)" >&2
  exit 2
fi

tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT

# Drop any existing SOFI-tagged line for this exact name (idempotent for both ops).
if [ -f "$HOSTS" ]; then
  awk -v n="$name" -v m="$MARKER" '!(index($0, m) && $2 == n)' "$HOSTS" > "$tmp"
else
  : > "$tmp"
fi

case "$op" in
  add) printf '127.0.0.1\t%s\t%s\n' "$name" "$MARKER" >> "$tmp" ;;
  del) : ;;  # already filtered out above
  *)   usage ;;
esac

# Atomic replace, preserve perms.
cat "$tmp" > "$HOSTS"
echo "✓ hosts ${op}: $name"
