# SOFI server-plane config — copy to .env on the SERVER and edit. Never commit .env.
#   cp .env.example .env && nano .env

# Your real domain (nameservers on Cloudflare, DNS-only / grey cloud).
DOMAIN=zanjour.com

# Subdomain the NetBird dashboard + control plane live on → netbird.zanjour.com
NETBIRD_SUBDOMAIN=netbird

# Server's PUBLIC IP — only used in the printed checklist for the A-records you
# create by hand in Cloudflare. Leave blank if your IP is dynamic (see README:
# Cloudflare DDNS).
SERVER_PUBLIC_IP=

# The mesh CIDR NetBird hands out (default 100.64.0.0/10). Used for the SSH
# cutover rule. Leave as-is unless you changed NetBird's IP range.
MESH_CIDR=100.64.0.0/10
